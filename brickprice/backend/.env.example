# BrickPrice Environment Variables
# Copy this file to .env and fill in your values

# Database path (leave as-is for local development)
DB_PATH=brickprice.db

# Amazon Associates API (optional but recommended for real Amazon prices)
# Sign up at: https://associates.amazon.com
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Walmart API (optional, for real Walmart prices)
# Sign up at: https://developer.walmart.com
WALMART_CONSUMER_ID=

# For production deployment on Railway/Render
# PORT=8000
